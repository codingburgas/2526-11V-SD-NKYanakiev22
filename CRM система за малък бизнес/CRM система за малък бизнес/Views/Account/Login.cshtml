@model CrmSmallBusiness.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="auth-shell">
    <div class="auth-card">
        <p class="eyebrow">Secure Access</p>
        <h1>Sign in</h1>
        <p class="text-muted">Use your saved account to access the CRM system.</p>

        <form asp-action="Login" method="post" class="mt-4">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <div class="form-text">Allowed domains: gmail.com, abv.bg, outlook.com, yahoo.com, hotmail.com, icloud.com</div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <div class="password-field">
                    <input asp-for="Password" class="form-control" />
                    <button type="button" class="btn btn-outline-secondary toggle-password" data-target="Password">Show</button>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>
            <button type="submit" class="btn btn-primary w-100">Login</button>
        </form>

        <p class="auth-link mt-4">
            No account yet?
            <a asp-action="Register">Create one</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
