@model CrmSmallBusiness.ViewModels.MyBusinessesViewModel
@using System.Globalization
@{
    ViewData["Title"] = "My Businesses";
    var euroCulture = CultureInfo.GetCultureInfo("fr-FR");
}

<section class="page-header">
    <p class="eyebrow">Owner Workspace</p>
    <h1>My businesses</h1>
    <p>Register a new business, update the ones you own, and review everyone who invested in them.</p>
</section>

@if (TempData["BusinessMessage"] is string message)
{
    <div class="alert alert-success" role="alert">
        @message
    </div>
}

@if (TempData["BusinessError"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}

<section class="row g-4">
    <div class="col-xl-4">
        <div class="content-card h-100">
            <h2 class="mb-3">Register business</h2>
            <form asp-action="Create" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="CreateForm.Name" class="form-label"></label>
                    <input asp-for="CreateForm.Name" class="form-control" />
                    <span asp-validation-for="CreateForm.Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CreateForm.OwnerName" class="form-label"></label>
                    <input asp-for="CreateForm.OwnerName" class="form-control" />
                    <span asp-validation-for="CreateForm.OwnerName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CreateForm.Email" class="form-label"></label>
                    <input asp-for="CreateForm.Email" class="form-control" />
                    <span asp-validation-for="CreateForm.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CreateForm.PhoneNumber" class="form-label"></label>
                    <input asp-for="CreateForm.PhoneNumber" class="form-control" />
                    <span asp-validation-for="CreateForm.PhoneNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CreateForm.Industry" class="form-label"></label>
                    <input asp-for="CreateForm.Industry" class="form-control" />
                    <span asp-validation-for="CreateForm.Industry" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CreateForm.Address" class="form-label"></label>
                    <input asp-for="CreateForm.Address" class="form-control" />
                    <span asp-validation-for="CreateForm.Address" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CreateForm.Description" class="form-label"></label>
                    <textarea asp-for="CreateForm.Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="CreateForm.Description" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Save business</button>
            </form>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="d-grid gap-3">
            @if (Model.Businesses.Count == 0)
            {
                <div class="content-card">
                    <p class="text-muted mb-0">You have not registered any businesses yet.</p>
                </div>
            }
            else
            {
                @foreach (var business in Model.Businesses)
                {
                    <article class="content-card">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <h2 class="h4 mb-1">@business.Form.Name</h2>
                                @if (business.IsSeededExample)
                                {
                                    <span class="badge text-bg-secondary">App example</span>
                                }
                            </div>
                            <div class="text-end">
                                <div><strong>@business.TotalInvested.ToString("C", euroCulture)</strong></div>
                                <div class="small text-muted">@business.InvestorCount investor(s)</div>
                            </div>
                        </div>

                        <form asp-action="Update" method="post" novalidate class="mb-4">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="businessId" value="@business.Id" />

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label" for="name-@business.Id">Business name</label>
                                    <input id="name-@business.Id" name="Name" value="@business.Form.Name" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="owner-@business.Id">Owner name</label>
                                    <input id="owner-@business.Id" name="OwnerName" value="@business.Form.OwnerName" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="email-@business.Id">Email</label>
                                    <input id="email-@business.Id" name="Email" value="@business.Form.Email" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="phone-@business.Id">Phone number</label>
                                    <input id="phone-@business.Id" name="PhoneNumber" value="@business.Form.PhoneNumber" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="industry-@business.Id">Industry</label>
                                    <input id="industry-@business.Id" name="Industry" value="@business.Form.Industry" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="address-@business.Id">Address</label>
                                    <input id="address-@business.Id" name="Address" value="@business.Form.Address" class="form-control" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="description-@business.Id">Description</label>
                                    <textarea id="description-@business.Id" name="Description" class="form-control" rows="4">@business.Form.Description</textarea>
                                </div>
                            </div>

                            <div class="mt-3">
                                <button type="submit" class="btn btn-primary">Save changes</button>
                            </div>
                        </form>

                        <div class="border-top pt-3">
                            <h3 class="h6">Investors</h3>
                            @if (business.Investors.Count == 0)
                            {
                                <p class="small text-muted mb-0">No donations or investments yet.</p>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle mb-0">
                                        <thead>
                                        <tr>
                                            <th>Investor</th>
                                            <th>Amount</th>
                                            <th>Message</th>
                                            <th>Date</th>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        @foreach (var investor in business.Investors)
                                        {
                                            <tr>
                                                <td>@investor.InvestorName</td>
                                                <td>@investor.Amount.ToString("C", euroCulture)</td>
                                                <td>@investor.Note</td>
                                                <td>@investor.CreatedOnUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </article>
                }
            }
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
