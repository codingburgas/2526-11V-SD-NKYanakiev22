@model CrmSmallBusiness.ViewModels.BusinessIndexViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Businesses";
    var euroCulture = CultureInfo.GetCultureInfo("fr-FR");
}

<section class="page-header">
    <p class="eyebrow">Business Registry</p>
    <h1>Register a business</h1>
    <p>Every signed-in user can add a business. Saved businesses stay in the database and appear again when the app starts.</p>
</section>

@if (TempData["BusinessMessage"] is string message)
{
    <div class="alert alert-success" role="alert">
        @message
    </div>
}

@if (TempData["BusinessError"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}

<section class="row g-4">
    <div class="col-lg-5">
        <div class="content-card h-100">
            <h2 class="mb-3">Business information</h2>
            <form asp-action="Create" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Form.Name" class="form-label"></label>
                    <input asp-for="Form.Name" class="form-control" />
                    <span asp-validation-for="Form.Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Form.OwnerName" class="form-label"></label>
                    <input asp-for="Form.OwnerName" class="form-control" />
                    <span asp-validation-for="Form.OwnerName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Form.Email" class="form-label"></label>
                    <input asp-for="Form.Email" class="form-control" />
                    <span asp-validation-for="Form.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Form.PhoneNumber" class="form-label"></label>
                    <input asp-for="Form.PhoneNumber" class="form-control" />
                    <span asp-validation-for="Form.PhoneNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Form.Industry" class="form-label"></label>
                    <input asp-for="Form.Industry" class="form-control" />
                    <span asp-validation-for="Form.Industry" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Form.Address" class="form-label"></label>
                    <input asp-for="Form.Address" class="form-control" />
                    <span asp-validation-for="Form.Address" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Form.Description" class="form-label"></label>
                    <textarea asp-for="Form.Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Form.Description" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Save business</button>
            </form>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="content-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="mb-0">Business catalog</h2>
                <span class="text-muted small">@Model.Businesses.Count total</span>
            </div>

            @if (Model.Businesses.Count == 0)
            {
                <p class="text-muted mb-0">No businesses have been registered yet.</p>
            }
            else
            {
                <div class="d-grid gap-3">
                    @foreach (var business in Model.Businesses)
                    {
                        <article class="border rounded p-3">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <h3 class="h5 mb-0">@business.Name</h3>
                                        @if (business.IsSeededExample)
                                        {
                                            <span class="badge text-bg-secondary">App example</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-primary">User registered</span>
                                        }
                                    </div>
                                    <div class="small text-muted">Owner: @business.OwnerName</div>
                                    <div class="small text-muted">Saved: @business.CreatedOnUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                                </div>
                                <div class="text-end">
                                    <div><strong>@business.TotalInvested.ToString("C", euroCulture)</strong></div>
                                    <div class="small text-muted">@business.InvestorCount investor(s)</div>
                                </div>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <div><strong>Industry:</strong> @business.Industry</div>
                                    <div><strong>Email:</strong> @business.Email</div>
                                    <div><strong>Phone:</strong> @business.PhoneNumber</div>
                                </div>
                                <div class="col-md-6">
                                    <div><strong>Address:</strong> @business.Address</div>
                                    <div class="small text-muted mt-2">@business.Description</div>
                                </div>
                            </div>

                            <form asp-action="Invest" method="post" class="row g-2 align-items-end mb-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="businessId" value="@business.Id" />
                                <div class="col-md-3">
                                    <label class="form-label" for="amount-@business.Id">Amount</label>
                                    <input id="amount-@business.Id" name="Amount" type="number" min="0.01" step="0.01" class="form-control" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="note-@business.Id">Message</label>
                                    <input id="note-@business.Id" name="Note" class="form-control" placeholder="Short note for the owner" />
                                </div>
                                <div class="col-md-3">
                                    <button type="submit" class="btn btn-outline-primary w-100">Contribute / Invest</button>
                                </div>
                            </form>

                            @if (business.IsOwnedByCurrentUser)
                            {
                                <div class="border-top pt-3">
                                    <h4 class="h6">Investors visible to you</h4>
                                    @if (business.Investors.Count == 0)
                                    {
                                        <p class="small text-muted mb-0">No investments yet.</p>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-sm align-middle mb-0">
                                                <thead>
                                                <tr>
                                                    <th>Investor</th>
                                                    <th>Amount</th>
                                                    <th>Message</th>
                                                    <th>Date</th>
                                                </tr>
                                                </thead>
                                                <tbody>
                                                @foreach (var investor in business.Investors)
                                                {
                                                    <tr>
                                                        <td>@investor.InvestorName</td>
                                                        <td>@investor.Amount.ToString("C", euroCulture)</td>
                                                        <td>@investor.Note</td>
                                                        <td>@investor.CreatedOnUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                                    </tr>
                                                }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            }
                        </article>
                    }
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
