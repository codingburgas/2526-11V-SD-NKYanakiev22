@model CrmSmallBusiness.ViewModels.DealListViewModel
@using System.Globalization
@using CrmSmallBusiness.Domain.Enums
@{
    ViewData["Title"] = "Deals";
    var euroCulture = CultureInfo.GetCultureInfo("fr-FR");
}

<section class="page-header">
    <p class="eyebrow">Deals & Pipeline</p>
    <h1>Deals</h1>
    <p>Business owners can create and track deals for the businesses they registered in the system.</p>
</section>

@if (TempData["DealMessage"] is string dealMessage)
{
    <div class="alert alert-success" role="alert">
        @dealMessage
    </div>
}

@if (TempData["DealError"] is string dealError)
{
    <div class="alert alert-danger" role="alert">
        @dealError
    </div>
}

<section class="row g-4">
    <div class="col-lg-4">
        <div class="content-card h-100">
            <h2 class="mb-3">Add deal</h2>
            <form asp-action="Create" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="CreateForm.BusinessId" class="form-label"></label>
                    <select asp-for="CreateForm.BusinessId" class="form-select">
                        <option value="">Select a business</option>
                        @foreach (var business in Model.OwnedBusinesses)
                        {
                            <option value="@business.Id">@business.Name</option>
                        }
                    </select>
                    <span asp-validation-for="CreateForm.BusinessId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CreateForm.Title" class="form-label"></label>
                    <input asp-for="CreateForm.Title" class="form-control" />
                    <span asp-validation-for="CreateForm.Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CreateForm.ContactName" class="form-label"></label>
                    <input asp-for="CreateForm.ContactName" class="form-control" />
                    <span asp-validation-for="CreateForm.ContactName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CreateForm.Value" class="form-label"></label>
                    <input asp-for="CreateForm.Value" class="form-control" type="number" step="0.01" min="0.01" />
                    <span asp-validation-for="CreateForm.Value" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CreateForm.Stage" class="form-label"></label>
                    <select asp-for="CreateForm.Stage" asp-items="Html.GetEnumSelectList<DealStage>()" class="form-select"></select>
                    <span asp-validation-for="CreateForm.Stage" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CreateForm.ExpectedCloseDate" class="form-label"></label>
                    <input asp-for="CreateForm.ExpectedCloseDate" class="form-control" type="date" />
                    <span asp-validation-for="CreateForm.ExpectedCloseDate" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Create deal</button>
            </form>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="content-card h-100">
            <h2 class="mb-3">Your deals</h2>
            @if (Model.Deals.Count == 0)
            {
                <p class="text-muted mb-0">You have not created any deals yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                        <tr>
                            <th>Deal</th>
                            <th>Business / Contact</th>
                            <th>Stage</th>
                            <th>Value</th>
                            <th>Expected close</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var deal in Model.Deals)
                        {
                            <tr>
                                <td>@deal.Title</td>
                                <td>@deal.CustomerName</td>
                                <td>@deal.Stage</td>
                                <td>@deal.Value.ToString("C", euroCulture)</td>
                                <td>@deal.ExpectedCloseDate.ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
