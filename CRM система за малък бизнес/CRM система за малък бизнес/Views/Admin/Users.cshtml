@model CrmSmallBusiness.ViewModels.UserManagementViewModel
@{
    ViewData["Title"] = "User Management";
}

<section class="page-header">
    <p class="eyebrow">Admin Control</p>
    <h1>User roles</h1>
    <p>Admins can promote users to <strong>Manager</strong> or change them back to <strong>User</strong>.</p>
</section>

<div class="content-card">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Current role</th>
                <th>Change role</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@user.CurrentRole</td>
                    <td>
                        <form asp-action="UpdateRole" method="post" class="role-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="UserId" value="@user.UserId" />
                            <select name="Role" class="form-select">
                                @if (user.CurrentRole == "User")
                                {
                                    <option value="User" selected>User</option>
                                }
                                else
                                {
                                    <option value="User">User</option>
                                }
                                @if (user.CurrentRole == "Manager")
                                {
                                    <option value="Manager" selected>Manager</option>
                                }
                                else
                                {
                                    <option value="Manager">Manager</option>
                                }
                                @if (user.CurrentRole == "Admin")
                                {
                                    <option value="Admin" selected>Admin</option>
                                }
                                else
                                {
                                    <option value="Admin">Admin</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-outline-primary">Save</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
