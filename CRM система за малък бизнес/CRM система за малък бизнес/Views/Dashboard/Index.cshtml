@model CrmSmallBusiness.ViewModels.DashboardViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Dashboard";
    var euroCulture = CultureInfo.GetCultureInfo("fr-FR");
}

<section class="hero-panel mb-4">
    <div>
        <p class="eyebrow">CRM small business system</p>
        <h1>Dashboard for businesses, investors, and deals</h1>
        <p class="hero-copy">
            The dashboard combines registered businesses in the system with owner and deal activity so users can see who is active and what is moving in the pipeline.
        </p>
    </div>
</section>

<section class="row g-3 mb-4">
    <div class="col-md-3">
        <article class="metric-card">
            <span>Customers</span>
            <strong>@Model.TotalCustomers</strong>
        </article>
    </div>
    <div class="col-md-3">
        <article class="metric-card">
            <span>Active deals</span>
            <strong>@Model.ActiveDeals</strong>
        </article>
    </div>
    <div class="col-md-3">
        <article class="metric-card">
            <span>Pipeline value</span>
            <strong>@Model.TotalPipelineValue.ToString("C", euroCulture)</strong>
        </article>
    </div>
    <div class="col-md-3">
        <article class="metric-card">
            <span>Conversion rate</span>
            <strong>@Model.ConversionRate%</strong>
        </article>
    </div>
</section>

<section class="row g-4">
    <div class="col-lg-6">
        <div class="content-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>Registered owners</h2>
                <a class="btn btn-sm btn-outline-primary" asp-controller="Businesses" asp-action="Index">View businesses</a>
            </div>

            @if (Model.RegisteredOwners.Count == 0)
            {
                <p class="text-muted mb-0">No business owners have registered a business yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                        <tr>
                            <th>Owner</th>
                            <th>Business</th>
                            <th>Email</th>
                            <th>Industry</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var owner in Model.RegisteredOwners)
                        {
                            <tr>
                                <td>@owner.OwnerName</td>
                                <td>@owner.BusinessName</td>
                                <td>@owner.Email</td>
                                <td>@owner.Industry</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
    <div class="col-lg-6">
        <div class="content-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>Upcoming deals</h2>
                <a class="btn btn-sm btn-outline-primary" asp-controller="Deals" asp-action="Index">Pipeline</a>
            </div>

            @if (Model.UpcomingDeals.Count == 0)
            {
                <p class="text-muted mb-0">No active business deals have been created yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                        <tr>
                            <th>Deal</th>
                            <th>Business / Contact</th>
                            <th>Stage</th>
                            <th>Close date</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var deal in Model.UpcomingDeals)
                        {
                            <tr>
                                <td>@deal.Title</td>
                                <td>@deal.CustomerName</td>
                                <td>@deal.Stage</td>
                                <td>@deal.ExpectedCloseDate.ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>
