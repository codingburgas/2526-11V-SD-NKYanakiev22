<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - CRM Small Business</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/CrmSmallBusiness.styles.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg crm-navbar">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">CRM Small Business</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse justify-content-between" id="mainNav">
                <ul class="navbar-nav gap-lg-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Customers" asp-action="Index">Customers</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Deals" asp-action="Index">Deals</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Businesses" asp-action="Index">Businesses</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Users">Users</a>
                            </li>
                        }
                    }
                </ul>
                <div class="auth-nav">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="navbar-text small text-light-subtle">Signed in as @User.Identity.Name</span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-light btn-sm">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                        <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Register">Register</a>
                    }
                </div>
            </div>
        </div>
    </nav>
</header>
<div class="container py-4">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="footer">
    <div class="container">
        CRM project foundation with ASP.NET Core MVC, EF Core Identity and SQLite.
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
